# Copy to .env and fill in. .env is gitignored — never commit your key.

# Model providers — set the one(s) your config uses (provider: in the YAML):
ANTHROPIC_API_KEY=sk-ant-...      # provider: anthropic
# OPENAI_API_KEY=sk-...           # provider: openai (OpenAI/Codex)
#                                 # provider: ollama needs no key

# Optional: raises PubMed E-utilities rate limit from 3 -> 10 req/s.
# The literature tool works without it (anonymous, 3 req/s).
# NCBI_API_KEY=...
